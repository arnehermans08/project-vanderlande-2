#!/usr/bin/env node
console.log("🚀 Start API-FE op poort 5000");

const express = require('express');
const axios = require('axios');
const cors = require('cors');  
const app = express();

app.use(cors());
app.use(express.json());

// ===== Bestaande routes =====

// Realtime data (voor de tabel)
app.get('/realtimedata', async (req, res) => {
  console.log("Website vraagt realtime data");

  try {
    const antwoord = await axios.get('http://vanderlande-api-be:8080/data');
    res.json({
      success: true,
      data: antwoord.data
    });
  } catch (fout) {
    res.json({
      success: false,
      error: "Kan geen data krijgen van database"
    });
  }
});

// Data voor grafiek
app.get('/grafiekendata', async (req, res) => {
  console.log("Website vraagt grafiek data");

  try {
    const antwoord = await axios.get('http://vanderlande-api-be:8080/data');
    const metingen = antwoord.data;

    const labels = [];
    const waarden = [];

    for (let m of metingen) {
      labels.push(new Date(m.tijd).toLocaleTimeString());
      waarden.push(m.waarde);
    }

    res.json({
      labels: labels,
      datasets: [{
        label: 'Sensor values',
        data: waarden,
        borderColor: 'blue'
      }]
    });
  } catch (fout) {
    res.json({ labels: [], datasets: [] });
  }
});

// ===== Nieuwe routes voor configuratie =====

// Haal alle cart configuraties op
app.get('/config/carts', async (req, res) => {
  try {
    const response = await axios.get('http://vanderlande-api-be:8080/config/carts');
    res.json(response.data);
  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});

// Haal 1 cart configuratie op
app.get('/config/carts/:cartId', async (req, res) => {
  try {
    const response = await axios.get(`http://vanderlande-api-be:8080/config/carts/${req.params.cartId}`);
    res.json(response.data);
  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});

// Update of maak cart configuratie
app.put('/config/carts/:cartId', async (req, res) => {
  try {
    const response = await axios.put(`http://vanderlande-api-be:8080/config/carts/${req.params.cartId}`, req.body);
    res.json(response.data);
  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});

// Verwijder cart configuratie
app.delete('/config/carts/:cartId', async (req, res) => {
  try {
    const response = await axios.delete(`http://vanderlande-api-be:8080/config/carts/${req.params.cartId}`);
    res.json(response.data);
  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});

// Gegroepeerde data per cart
app.get('/grouped-data', async (req, res) => {
  try {
    const response = await axios.get('http://vanderlande-api-be:8080/grouped-data');
    res.json(response.data);
  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});

// Health check
app.get('/health', (req, res) => {
  res.send("API-FE leeft! 🎉");
});

// Start de server
app.listen(5000, () => {
  console.log("API-FE klaar! Luistert op poort 5000");
  console.log("   Realtime data: http://localhost:5000/realtimedata");
  console.log("   Grafiek data: http://localhost:5000/grafiekendata");
  console.log("   Configuratie: http://localhost:5000/config/carts");
});