global.crypto = crypto;

console.log("🚀 Start API-BE op poort 8080");

let express = require('express');
let mongoose = require('mongoose');
let app = express();

app.use(express.json());

// ===== 1. Schema voor sensor metingen =====
let SensorSchema = new mongoose.Schema({
  id: Number,
  type: String,
  waarde: Number,
  tijd: { type: Date, default: Date.now }
});

let Meting = mongoose.model('Meting', SensorSchema);

// ===== 2. Schema voor cart configuratie =====
let CartConfigSchema = new mongoose.Schema({
  cartId: { type: Number, unique: true, required: true },
  name: { type: String, default: "Carrier" },
  espIds: [Number],
  locationSensor: { type: String, default: "huskylensLocatie" },
  colorSensor: { type: String, default: "az1" },
  colorThresholds: [Number],
  active: { type: Boolean, default: true }
});

let CartConfig = mongoose.model('CartConfig', CartConfigSchema);

// ===== 3. Routes =====

app.post('/data', async (req, res) => {
  console.log("📥 Nieuwe data binnen:", req.body);
  try {
    let nieuweMeting = new Meting(req.body);
    await nieuweMeting.save();
    console.log("✅ Opgeslagen in database");
    res.send("OK");
  } catch (fout) {
    console.log("❌ Fout:", fout);
    res.status(500).send("Fout bij opslaan");
  }
});

app.get('/data', async (req, res) => {
  console.log("📤 Data opgevraagd");
  let metingen = await Meting.find().sort({ tijd: -1 }).limit(20);
  res.json(metingen);
});

app.get('/config/carts', async (req, res) => {
  try {
    let configs = await CartConfig.find();
    res.json({ success: true, data: configs });
  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});

app.get('/config/carts/:cartId', async (req, res) => {
  try {
    let config = await CartConfig.findOne({ cartId: parseInt(req.params.cartId) });
    if (!config) {
      return res.status(404).json({ success: false, error: "Cart not found" });
    }
    res.json({ success: true, data: config });
  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});

app.put('/config/carts/:cartId', async (req, res) => {
  try {
    let cartId = parseInt(req.params.cartId);
    let { espIds, name, locationSensor, colorSensor, colorThresholds, active } = req.body;

    let updateData = {};
    if (espIds !== undefined) updateData.espIds = espIds;
    if (name !== undefined) updateData.name = name;
    if (locationSensor !== undefined) updateData.locationSensor = locationSensor;
    if (colorSensor !== undefined) updateData.colorSensor = colorSensor;
    if (colorThresholds !== undefined) updateData.colorThresholds = colorThresholds;
    if (active !== undefined) updateData.active = active;

    let config = await CartConfig.findOneAndUpdate(
      { cartId: cartId },
      { $set: updateData },
      { upsert: true, new: true }
    );

    res.json({ success: true, data: config });
  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});

// GET /sensor-data/:espId/:sensorType - haal laatste 20 metingen van specifieke sensor
app.get('/sensor-data/:espId/:sensorType', async (req, res) => {
  try {
    let espId = parseInt(req.params.espId);
    let sensorType = req.params.sensorType;

    let metingen = await Meting.find({
      id: espId,
      type: sensorType
    })
      .sort({ tijd: -1 })  // Nieuwste eerst
      .limit(20);          // Laatste 20 metingen

    // Draai om zodat de grafiek van oud naar nieuw gaat
    metingen.reverse();

    res.json({
      success: true,
      data: metingen
    });
  } catch (err) {
    console.error("❌ Sensor data error:", err);
    res.status(500).json({ success: false, error: err.message });
  }
});

app.delete('/config/carts/:cartId', async (req, res) => {
  try {
    let cartId = parseInt(req.params.cartId);
    let result = await CartConfig.deleteOne({ cartId: cartId });

    if (result.deletedCount === 0) {
      return res.status(404).json({ success: false, error: "Cart not found" });
    }

    res.json({ success: true });
  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});

app.get('/grouped-data', async (req, res) => {
  try {
    let [configs, metingen] = await Promise.all([
      CartConfig.find({ active: true }),
      Meting.find().sort({ tijd: -1 }).limit(100)
    ]);

    let result = {};

    for (let config of configs) {
      let cartData = {
        cartId: config.cartId,
        name: config.name,
        latestValues: {},
        locationValue: null,
        colorValue: null,
        timestamp: null
      };

      let cartMetingen = metingen.filter(m => config.espIds.includes(m.id));

      for (let m of cartMetingen) {
        cartData.latestValues[m.type] = m.waarde;
        cartData.timestamp = m.tijd;
      }

      for (let [sensorType, waarde] of Object.entries(cartData.latestValues)) {
        if (sensorType.toLowerCase().endsWith('locatie')) {
          cartData.locationValue = waarde;
          break;
        }
      }

      if (config.colorSensor && cartData.latestValues[config.colorSensor] !== undefined) {
        cartData.colorValue = cartData.latestValues[config.colorSensor];
      } else {
        for (let [sensorType, waarde] of Object.entries(cartData.latestValues)) {
          if (!sensorType.toLowerCase().endsWith('locatie') && typeof waarde === 'number') {
            cartData.colorValue = waarde;
            break;
          }
        }
      }

      result[config.cartId] = cartData;
    }

    res.json({ success: true, data: result });
  } catch (err) {
    console.error("❌ Grouped data error:", err);
    res.status(500).json({ success: false, error: err.message });
  }
});

